<Window x:Class="PersikMusic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Persik Hi-Fi" Width="1100" Height="750"
        Background="#0F0F0F" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="15"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#FF7A33"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#161618"/>
        <SolidColorBrush x:Key="PlayerBg" Color="#1C1C1E"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SidebarBg}" CornerRadius="15,0,0,0">
            <StackPanel Margin="10,30,10,0">
                <StackPanel Orientation="Horizontal" Margin="10,0,0,30">
                    <Ellipse Width="45" Height="45" Fill="#444"/>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Гость" Foreground="White" FontWeight="Bold" FontSize="15"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="МЕНЮ" Foreground="#555" FontSize="11" FontWeight="Bold" Margin="15,0,0,10"/>
                <TextBlock Text="ПЛЕЙЛИСТЫ" Foreground="#555" FontSize="11" FontWeight="Bold" Margin="15,20,0,10"/>
                <Button Content="🏠 Главная" Tag="Сюда вставь ID папки, который плучил на диске по ссылке" Style="{StaticResource NavButton}" Click="Folder_Click"/>
                <Button Content="🎵 Оригинальные песни" Tag="Сюда вставь ID папки, который плучил на диске по ссылке" Style="{StaticResource NavButton}" Click="Folder_Click"/>
                <Button Content="🎖️ 9 Мая" Tag="Сюда вставь ID папки, который плучил на диске по ссылке" Style="{StaticResource NavButton}" Click="Folder_Click"/>
                <Button Content="❤️ Пятничные новинки!" Tag="Сюда вставь ID папки, который плучил на диске по ссылке" Style="{StaticResource NavButton}" Click="Folder_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Margin="30,30,30,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="ОТКРЫТАЯ ПЕРСИК МУЗЫКА" Foreground="White" FontSize="26" FontWeight="Black" FontStyle="Italic"/>
                <Border HorizontalAlignment="Right" Background="#1E1E1E" CornerRadius="20" Width="250" Height="40">
                    <TextBlock Text="Поиск артистов, Песен... (в разработке)" Foreground="#666" VerticalAlignment="Center" Margin="15,0,0,0"/>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="CategoryTitle" Text="выбери плейлист, это просто заглушка." Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <ListBox x:Name="SongListView" Background="Transparent" BorderThickness="0" MouseDoubleClick="Song_DoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="160" Height="210" Background="#1E1E1E" CornerRadius="12" Margin="0,0,15,15" Padding="12">
                                    <StackPanel>
                                        <Border Width="136" Height="136" Background="#333" CornerRadius="8" Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                        <Grid Margin="0,5,0,0">
                                            <Button Content="❤️" Tag="{Binding}" Click="ToggleFavorite_Click" Foreground="{Binding FavoriteBrush}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource PlayerBg}" CornerRadius="0,0,15,15">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="50" Height="50" Background="#444" CornerRadius="6"/>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Выберите песню" Foreground="White" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Имей звук даже там где его нет." Foreground="#888" FontSize="12" RenderTransformOrigin="0.5,0.5" Height="21" Width="184">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-0.253"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Button Content="🔀" Background="Transparent" Foreground="#888" BorderThickness="0" FontSize="16" Margin="0,0,20,0"/>
                        <Button Content="⏮" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" Margin="0,0,20,0"/>
                        <Button x:Name="PlayPauseBtn" Content="▶" Click="PlayPause_Click" Width="45" Height="45" Background="{StaticResource AccentColor}" Foreground="White" FontSize="20">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="22.5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="⏭" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" Margin="20,0,0,0"/>
                        <Button Content="🔁" Background="Transparent" Foreground="#888" BorderThickness="0" FontSize="16" Margin="20,0,0,0"/>
                    </StackPanel>
                    <Slider x:Name="TimelineSlider" Maximum="100" Thumb.DragStarted="Timeline_DragStarted" Thumb.DragCompleted="Timeline_DragCompleted" Foreground="{StaticResource AccentColor}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Hi-Fi Эксклюзив!" Foreground="#4ADE80" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="🔊" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="VolumeSlider" Width="116" Value="0.7" Maximum="1" ValueChanged="Volume_Changed" VerticalAlignment="Center" Foreground="{StaticResource AccentColor}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>